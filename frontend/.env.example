# Set to true only for offline demo (static mock data, no Gemini).
# EXPO_PUBLIC_USE_MOCK_SCAN=true

# Backend URL — use your PC LAN IP (same as Expo QR code IP).
EXPO_PUBLIC_API_URL=http://192.168.1.3:3000

# Expo CLI: skip online dependency check (fixes "TypeError: fetch failed" on weak/no internet).
# EXPO_OFFLINE=1
